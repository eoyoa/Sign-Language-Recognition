{
  "name": "sign-language-recognition-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build -w packages/lib && npm run dev -w packages/demo",
    "build": "npm run build -w packages/lib && npm run build -w packages/demo",
    "build:lib": "npm run build -w packages/lib",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.58.0"
  }
}
